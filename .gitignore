# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
*.egg
.eggs/

# Virtual environments
.venv/
venv/
env/
ENV/
.python-version

# --- Jupyter ---
.ipynb_checkpoints/
*.ipynb_checkpoints
profile_default/
ipython_config.py

# --- Data & outputs (keep raw source tracked, ignore derived artefacts) ---
data/cleaned/*.csv
output/charts/*.png
output/charts/*.html
output/tables/*.csv
output/map/*.html
*.db
*.sqlite
*.sqlite3

# Keep folder structure in Git even when empty
!data/cleaned/.gitkeep
!output/charts/.gitkeep
!output/tables/.gitkeep
!output/map/.gitkeep

# --- Environment / secrets ---
.env
.env.local
*.key
secrets.json

# --- Editor / OS ---
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# --- Logs & temp ---
*.log
*.tmp
*.bak
*.old
tmp/
temp/
